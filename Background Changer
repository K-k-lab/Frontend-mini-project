<!DOCTYPE html>
<html>
    <head>
        <title>
            Background Changer
        </title>
        <style>
            #nat{
                background-color: green;
                color:white;
                padding:3px;
            }
            #des{
                background-color: red;
                color: white;
                 padding:3px;
            }
            #div{
                width: 300px;
                border: 2px solid black;
                padding: 50px;
                text-align: center;
                margin-left: 600px;
                margin-top: 300px;
                background-color: white;
            }
            body{
                background-color: aqua;
            }
        </style>
    </head>
    <body>
        <div id="div">
        <h1>Background Changer</h1>
        <button onclick="nat()" id="nat">Nature</button>
        <button onclick="des()" id="des">Desert</button>
        </div>
        <script>
                let natureImages = [
"https://picsum.photos/id/1018/1200/800",
"https://picsum.photos/id/1015/1200/800",
"https://picsum.photos/id/1020/1200/800",
"https://picsum.photos/id/1039/1200/800"
            ];
            let desertImages=[
"https://picsum.photos/id/1002/1200/800",
"https://picsum.photos/id/1003/1200/800",
"https://picsum.photos/id/1016/1200/800",
"https://picsum.photos/id/1021/1200/800",
"https://picsum.photos/id/1036/1200/800"
            ];
            function nat(){
                let random=Math.floor(Math.random()*natureImages.length);
                document.body.style.backgroundImage="url('"+natureImages[random]+"')";
            }
            function des(){
                let ran=Math.floor(Math.random()*desertImages.length);
                document.body.style.backgroundImage="url('"+desertImages[ran]+"')";
            }
        </script>
    </body>
</html>
